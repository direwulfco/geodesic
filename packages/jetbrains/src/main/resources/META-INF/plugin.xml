<idea-plugin>
  <id>dev.geode.plugin</id>
  <name>Geode</name>
  <vendor email="info@hyperpace.ai" url="https://github.com/hyperpaced/geode">Geode</vendor>
  <description><![CDATA[
    <b>Geode — Auto-Topology Agent</b><br><br>
    AI-powered codebase topology analysis. Deep static analysis of your repositories
    produces Architecture Maps, Skill Files, and Gap Reports — all scored and prioritized.
    <br><br>
    <ul>
      <li>Architecture Map: full topology, layers, APIs, databases, auth patterns</li>
      <li>Skill File: machine-readable context package for build agents</li>
      <li>Gap Report: scored findings across 7 dimensions with P0–P3 prioritization</li>
    </ul>
    <br>
    Supports Anthropic, OpenAI, Gemini, Azure OpenAI, and Ollama (local).
  ]]></description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow
      id="Geode"
      anchor="right"
      factoryClass="dev.geode.plugin.toolwindow.GeodeToolWindowFactory"
      icon="/META-INF/geode.svg"
    />

    <applicationService
      serviceInterface="dev.geode.plugin.settings.GeodeSettings"
      serviceImplementation="dev.geode.plugin.settings.GeodeSettings"
    />

    <projectService
      serviceInterface="dev.geode.plugin.toolwindow.GeodeToolWindowService"
      serviceImplementation="dev.geode.plugin.toolwindow.GeodeToolWindowService"
    />

    <applicationConfigurable
      parentId="tools"
      instance="dev.geode.plugin.settings.GeodeSettingsConfigurable"
      id="dev.geode.plugin.settings.GeodeSettingsConfigurable"
      displayName="Geode"
    />

    <postStartupActivity
      implementation="dev.geode.plugin.GeodeStartup"
    />
  </extensions>

  <actions>
    <action
      id="Geode.Analyze"
      class="dev.geode.plugin.actions.AnalyzeAction"
      text="Run Geode Analysis"
      description="Analyze the current project with Geode"
      icon="/META-INF/geode.svg"
    >
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
