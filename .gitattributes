# Normalize line endings to LF on commit, checkout as LF on all platforms
* text=auto eol=lf

# Force binary — never mangle these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.jar binary
*.vsix binary
*.zip binary

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf
